    {
      "name": "Fornecedores",
      "item": [
        {
          "name": "Cadastrar Fornecedor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const json = pm.response.json();",
                  "    pm.collectionVariables.set('fornecedorId', json.id);",
                  "}",
                  "pm.test('Status 201', () => pm.response.to.have.status(201));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"razaoSocial\": \"Distribuidora Alfa Ltda\",\n  \"cnpj\": \"12345678000190\",\n  \"email\": \"contato@alfa.com.br\",\n  \"telefone\": \"11999990000\",\n  \"ativo\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/fornecedores",
              "host": ["{{baseUrl}}"],
              "path": ["fornecedores"]
            }
          }
        },
        {
          "name": "Listar Fornecedores",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/fornecedores?nome=&cnpj=",
              "host": ["{{baseUrl}}"],
              "path": ["fornecedores"],
              "query": [
                { "key": "nome", "value": "", "disabled": true },
                { "key": "cnpj", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Buscar Fornecedor por ID",
