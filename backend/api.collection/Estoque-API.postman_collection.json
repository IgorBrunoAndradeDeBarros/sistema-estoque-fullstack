    {
      "name": "Alertas",
      "item": [
        {
          "name": "Listar Alertas",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const json = pm.response.json();",
                  "    if (Array.isArray(json) && json.length > 0) {",
                  "        pm.collectionVariables.set('alertaId', json[0].id);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/alertas?lido=",
              "host": ["{{baseUrl}}"],
              "path": ["alertas"],
              "query": [
                { "key": "lido", "value": "false", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Contar Alertas Não Lidos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/alertas/count",
              "host": ["{{baseUrl}}"],
              "path": ["alertas", "count"]
            }
          }
        },
        {
          "name": "Marcar Alerta como Lido",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/alertas/{{alertaId}}/ler",
              "host": ["{{baseUrl}}"],
              "path": ["alertas", "{{alertaId}}", "ler"]
            }
          }
        },
        {
          "name": "Marcar Todos os Alertas como Lidos",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/alertas/ler-todos",
              "host": ["{{baseUrl}}"],
              "path": ["alertas", "ler-todos"]
