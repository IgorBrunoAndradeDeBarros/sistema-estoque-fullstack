            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"razaoSocial\": \"Distribuidora Alfa Ltda - ME\",\n  \"cnpj\": \"12345678000190\",\n  \"email\": \"financeiro@alfa.com.br\",\n  \"telefone\": \"11999991111\",\n  \"ativo\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/fornecedores/{{fornecedorId}}",
              "host": ["{{baseUrl}}"],
              "path": ["fornecedores", "{{fornecedorId}}"]
            }
          }
        },
        {
          "name": "Desativar Fornecedor",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/fornecedores/{{fornecedorId}}",
              "host": ["{{baseUrl}}"],
              "path": ["fornecedores", "{{fornecedorId}}"]
            }
          }
        }
